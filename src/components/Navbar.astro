---
import { Shield } from 'lucide-react';
---

<nav class="bg-white shadow-lg">
  <div class="container mx-auto px-6 py-4">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <Shield className="h-8 w-8 text-orange-600" />
        <span class="ml-3 text-xl font-bold">CyberShield</span>
      </div>
      
      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-8">
        <a href="/" class="text-gray-700 hover:text-orange-600">Home</a>
        <a href="/about" class="text-gray-700 hover:text-orange-600">About</a>
        <a href="/products" class="text-gray-700 hover:text-orange-600">Products</a>
        <button class="bg-orange-600 text-white px-6 py-2 rounded-lg hover:bg-orange-700">
          Contact Us
        </button>
      </div>

      <!-- Mobile Menu Button -->
      <button id="menuButton" class="md:hidden">
        <span class="menu-icon">☰</span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobileMenu" class="hidden md:hidden mt-4">
      <a href="/" class="block py-2 text-gray-700 hover:text-orange-600">Home</a>
      <a href="/about" class="block py-2 text-gray-700 hover:text-orange-600">About</a>
      <a href="/products" class="block py-2 text-gray-700 hover:text-orange-600">Products</a>
      <button class="w-full mt-4 bg-orange-600 text-white px-6 py-2 rounded-lg hover:bg-orange-700">
        Contact Us
      </button>
    </div>
  </div>
</nav>

<script>
  const menuButton = document.getElementById('menuButton');
  const mobileMenu = document.getElementById('mobileMenu');
  
  menuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>