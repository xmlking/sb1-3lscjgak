---
import Layout from '../layouts/Layout.astro';
import { Shield, Server, Cloud, Wifi, Lock, AlertTriangle } from 'lucide-react';

const products = [
  {
    icon: Shield,
    title: "Endpoint Protection",
    description: "Advanced endpoint security with AI-powered threat detection and response",
    features: [
      "Real-time malware protection",
      "Behavioral analysis",
      "Device control",
      "Automated response"
    ],
    price: "$15"
  },
  {
    icon: Server,
    title: "Network Security",
    description: "Complete network protection with advanced firewall and intrusion detection",
    features: [
      "Next-gen firewall",
      "Intrusion prevention",
      "Traffic analysis",
      "VPN support"
    ],
    price: "$25"
  },
  {
    icon: Cloud,
    title: "Cloud Security",
    description: "Secure your cloud infrastructure with enterprise-grade protection",
    features: [
      "Cloud workload protection",
      "Container security",
      "Access management",
      "Compliance monitoring"
    ],
    price: "$30"
  },
  {
    icon: AlertTriangle,
    title: "Threat Intelligence",
    description: "Stay ahead of threats with real-time intelligence and analytics",
    features: [
      "Global threat monitoring",
      "Predictive analytics",
      "Incident response",
      "Threat hunting"
    ],
    price: "$20"
  }
];
---

<Layout title="Products - CyberShield">
  <main class="min-h-screen bg-orange-50">
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-orange-700 to-orange-500 text-white py-20">
      <div class="container mx-auto px-6">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Our Security Solutions</h1>
        <p class="text-xl text-orange-200">Comprehensive cybersecurity products for modern enterprises</p>
      </div>
    </section>

    <!-- Main Products -->
    <section class="py-20">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          {products.map(product => (
            <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow">
              <div class="mb-6">
                <product.icon className="w-16 h-16 text-orange-600" />
              </div>
              <h3 class="text-2xl font-semibold mb-4">{product.title}</h3>
              <p class="text-gray-600 mb-6">{product.description}</p>
              <ul class="space-y-3 mb-6">
                {product.features.map(feature => (
                  <li class="flex items-center">
                    <Lock className="w-5 h-5 text-orange-600 mr-3" />
                    <span class="text-gray-700">{feature}</span>
                  </li>
                ))}
              </ul>
              <div class="text-2xl font-bold text-orange-600 mb-6">
                {product.price}<span class="text-gray-500 text-base">/user/month</span>
              </div>
              <button class="w-full bg-orange-600 text-white py-3 rounded-lg hover:bg-orange-700 transition-colors">
                Learn More
              </button>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="bg-orange-700 text-white py-16">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-6">Ready to Secure Your Business?</h2>
        <p class="text-xl mb-8">Contact our team for a personalized security assessment</p>
        <button class="bg-white text-orange-900 px-8 py-3 rounded-lg font-semibold hover:bg-orange-100">
          Get Started
        </button>
      </div>
    </section>
  </main>
</Layout>